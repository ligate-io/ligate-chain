# Copy to `.env` and fill in. `.env` is gitignored; never commit it.
#
# All values here are injected as env vars into the `ligate-node`
# container at startup. The compose file references them with the
# `${VAR:-default}` form so unset vars fall back to safe defaults.

# Chain image version. Pin to a specific tag for reproducible deploys
# (`0.3.0` is the latest devnet-1 release as of 2026-05-23). Set to
# `latest` to track the most recent release automatically; never use
# `latest` on production VMs.
LIGATE_VERSION=0.3.0

# Sequencer-mode hot key (hex). Holds Mocha TIA for blob inclusion.
# Read-only-mode operators leave empty.
#
# DO NOT commit your real signer key. Use a secret store (1Password,
# GCP Secret Manager, AWS Secrets Manager) and inject at runtime.
SOV_CELESTIA_SIGNER_KEY=

# Optional Mocha-provider auth token (QuickNode, Lava, etc.). Only
# needed if your `SOV_CELESTIA_RPC_URL` points at a provider that
# requires auth. Default Mocha public RPC doesn't.
SOV_CELESTIA_RPC_AUTH_TOKEN=

# Log level. `info,sov=info` is the default; bump to `debug` when
# triaging.
RUST_LOG=info,sov=info
