        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "clamp_min(-rate(celestia_node_da_signer_balance_utia{instance=~\"$instance\"}[$window]) * 86400 / 1e6, 0)",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "TIA draw-down rate (per $window)",
      "type": "stat"
    },
