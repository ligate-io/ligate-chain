{
  "rule": [
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 30,
        "matchesPrefix": ["snapshots/"],
        "matchesSuffix": ["-daily.tar.gz", "-daily.manifest.json"]
      }
    },
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 84,
        "matchesPrefix": ["snapshots/"],
        "matchesSuffix": ["-weekly.tar.gz", "-weekly.manifest.json"]
      }
    },
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 365,
        "matchesPrefix": ["snapshots/"],
        "matchesSuffix": ["-monthly.tar.gz", "-monthly.manifest.json"]
      }
    }
  ]
}
