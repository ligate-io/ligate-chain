{
  "rule": [
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 7,
        "matchesPrefix": ["*/hourly/"]
      }
    },
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 60,
        "matchesPrefix": ["*/daily/"]
      }
    },
    {
      "action": { "type": "Delete" },
      "condition": {
        "age": 365,
        "matchesPrefix": ["*/weekly/"]
      }
    }
  ]
}
