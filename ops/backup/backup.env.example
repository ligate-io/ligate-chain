# Ligate Chain backup env (template).
#
# Copy to /etc/ligate/backup.env on the sequencer VM with chmod 600,
# owned root:root, before enabling the ligate-backup-* timers.
#
# Variables consumed by scripts/backup-rocksdb.sh, invoked by the
# systemd template unit ligate-backup@<tier>.service.

# Required.
# Private GCS bucket the snapshots upload to. The bucket gets the
# lifecycle policy from ops/backup/gcs-lifecycle.json applied at
# create time (hourly: 7d retention, daily: 60d, weekly: 365d).
GCS_BUCKET=ligate-backups

# TIER is NOT set here. The systemd template unit
# `ligate-backup@.service` derives it from the instance name (`%i`),
# so the three timers map cleanly to three tier values:
#
#   ligate-backup-hourly.timer  → ligate-backup@hourly.service  → TIER=hourly
#   ligate-backup-daily.timer   → ligate-backup@daily.service   → TIER=daily
#   ligate-backup-weekly.timer  → ligate-backup@weekly.service  → TIER=weekly

# Required.
# Absolute path to the live RocksDB rollup data directory. On
# devnet-1 sequencer the chain config points at
# /opt/ligate/devnet-1/data-celestia, which is a symlink to
# /var/lib/ligate/rocksdb on the persistent disk. The backup script
# reads the physical path directly so the manifest records the real
# storage location (not the symlink).
LIGATE_STORAGE_DIR=/var/lib/ligate/rocksdb

# Required.
# Local stage dir for rsync --link-dest snapshots before GCS upload.
# Must be on the persistent disk (/var/lib/ligate) so the dedupe
# chain survives VM rebuilds. Created on first run, owned ligate:ligate.
LIGATE_SNAPSHOT_DIR=/var/lib/ligate/snapshots
